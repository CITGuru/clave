{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clave Launcher",
  "version": "0.1.0",
  "identifier": "com.clave.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1430",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Clave Launcher",
        "width": 960,
        "height": 700,
        "minWidth": 360,
        "minHeight": 480,
        "resizable": true,
        "theme": "Light"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
